{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provenance.dev/schemas/conformance-expected-outcome-0.3.schema.json",
  "title": "ExpectedOutcome",
  "type": "object",
  "required": [
    "policyOutcome",
    "receiptStatus",
    "reasonCodes",
    "persistedArtifacts",
    "auditEvents"
  ],
  "additionalProperties": false,
  "properties": {
    "policyOutcome": {
      "type": ["string", "null"],
      "enum": [
        "allow",
        "allow_with_attribution",
        "deny_no_permission",
        "deny_license_violation",
        "pending_owner_approval",
        null
      ]
    },
    "receiptStatus": {
      "type": ["string", "null"],
      "enum": [
        "accepted",
        "accepted_with_attribution_required",
        "accepted_unsigned",
        "rejected_invalid_signature",
        "rejected_unknown_source_entity",
        "rejected_policy",
        "rejected_no_permission",
        "rejected_license_violation",
        "pending_async",
        "pending_owner_approval",
        null
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/reasonCodeAssertion"
      }
    },
    "persistedArtifacts": {
      "type": "object",
      "required": ["activities", "claims", "receipts", "decisions"],
      "additionalProperties": false,
      "properties": {
        "activities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "receipts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decisions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "auditEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "status", "reasonCode"],
        "additionalProperties": false,
        "properties": {
          "phase": { "type": "string" },
          "status": { "type": "string" },
          "reasonCode": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "reasonCodeAssertion": {
      "title": "ReasonCodeAssertion",
      "type": "object",
      "required": ["code", "scope", "mustExist"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "scope": {
          "type": "string",
          "enum": ["bundle", "segment", "claim", "receipt", "validation", "policy"]
        },
        "mustExist": { "type": "boolean" }
      }
    }
  }
}
