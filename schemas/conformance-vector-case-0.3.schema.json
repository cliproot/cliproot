{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provenance.dev/schemas/conformance-vector-case-0.3.schema.json",
  "title": "ConformanceVectorCase",
  "type": "object",
  "required": [
    "vectorId",
    "title",
    "level",
    "category",
    "description",
    "requires",
    "tags",
    "status",
    "introducedIn",
    "updatedIn",
    "runner"
  ],
  "additionalProperties": false,
  "properties": {
    "vectorId": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
    "title": { "type": "string" },
    "level": { "type": "integer", "minimum": 1, "maximum": 5 },
    "category": { "type": "string" },
    "description": { "type": "string" },
    "requires": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "parseEnvelope",
          "validateEnvelope",
          "evaluatePolicy",
          "processTransferClaim",
          "verifyIdempotency"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "draft"]
    },
    "introducedIn": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updatedIn": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "runner": {
      "type": "object",
      "required": ["clock", "operations", "inputFiles", "expectedFile"],
      "additionalProperties": false,
      "properties": {
        "clock": {
          "type": "string",
          "format": "date-time"
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "parseEnvelope",
              "validateEnvelope",
              "evaluatePolicy",
              "processTransferClaim",
              "verifyIdempotency"
            ]
          }
        },
        "inputFiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        },
        "expectedFile": {
          "type": "string"
        }
      }
    }
  }
}
